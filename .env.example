# This is an example of your .env file format, which pnpm db:setup will create.
# Note: this must be .env, not .env.local, without further configuration changes.
POSTGRES_URL=postgresql://***
BASE_URL=http://localhost:3000
AUTH_SECRET=***

# Billing (Stripe). Phase 1 default: disabled.
# When BILLING_ENABLED=false the app runs without STRIPE_SECRET_KEY: Stripe
# API routes return 404, /pricing returns 404, the seed skips Stripe products,
# and billing-related UI (pricing nav link, subscription card) is hidden.
# Set both flags to 'true' and provide the Stripe keys to re-enable billing.
BILLING_ENABLED=false
NEXT_PUBLIC_BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Video calls (LiveKit). Optional — leave empty to disable video. When unset,
# the video room page shows a setup message and the app starts normally
# (these vars are never required at startup). Tokens are generated server-side
# from LIVEKIT_API_KEY / LIVEKIT_API_SECRET; the browser connects to
# NEXT_PUBLIC_LIVEKIT_URL (e.g. wss://your-project.livekit.cloud).
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# Realtime chat (Supabase Realtime). Optional — leave empty to disable. When
# unset, chat still works with server-rendered messages + manual refresh;
# realtime only adds live updates. Uses Supabase Broadcast (a content-free
# "new message" signal); message content is always fetched from the
# participant-guarded server, never sent over the realtime channel.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
