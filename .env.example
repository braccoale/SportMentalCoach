# This is an example of your .env file format, which pnpm db:setup will create.
# Note: this must be .env, not .env.local, without further configuration changes.
POSTGRES_URL=postgresql://***
BASE_URL=http://localhost:3000
AUTH_SECRET=***

# Billing (Stripe). Phase 1 default: disabled.
# When BILLING_ENABLED=false the app runs without STRIPE_SECRET_KEY: Stripe
# API routes return 404, /pricing returns 404, the seed skips Stripe products,
# and billing-related UI (pricing nav link, subscription card) is hidden.
# Set both flags to 'true' and provide the Stripe keys to re-enable billing.
BILLING_ENABLED=false
NEXT_PUBLIC_BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
